# Copy to `.env` and fill in real values for local development.
# All variables have safe defaults in app/core/config.py except where noted.

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me
LOG_LEVEL=INFO
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://opsgraph:opsgraph_dev@localhost:5432/opsgraph
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_URL=redis://localhost:6379/1

# ── Neo4j (optional graph backend) ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev
USE_NEO4J=false

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514
AGENT_TEMPERATURE=0.2
AGENT_MAX_TOKENS=4096

# ── Security ─────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
# Comma-separated channel IDs to scan for decision-worthy messages
SLACK_DECISION_CHANNEL_IDS=

# ── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_ORG=

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_SERVER=
JIRA_EMAIL=
JIRA_API_TOKEN=
# Comma-separated project keys to scope JQL search; empty = all accessible projects
JIRA_PROJECT_KEYS=

# ── Google Workspace ─────────────────────────────────────────────────────────
# Full JSON contents of a service-account key, as a single line
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SHARED_DRIVE_ID=

# ── Ingestion ────────────────────────────────────────────────────────────────
INGESTION_BATCH_SIZE=50
INGESTION_POLL_INTERVAL_SECONDS=60
INGESTION_WORKERS=4

# ── Vector store ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_SIMILARITY_THRESHOLD=0.75
VECTOR_TOP_K=10
